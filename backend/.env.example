# ── Database ─────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/gogo
DB_USERNAME=gogo_user
DB_PASSWORD=gogo_pass
DDL_AUTO=validate          # 프로덕션: validate | 로컬 초기 세팅: update

# ── JWT ──────────────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열 (openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-32-char-secret-key

# ── OAuth - Kakao ─────────────────────────────────────────────────
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=https://your-domain.com/api/auth/kakao/callback

# ── OAuth - Google ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ── App ───────────────────────────────────────────────────────────
FRONTEND_URL=https://your-vercel-domain.vercel.app

# ── JVM (선택) ────────────────────────────────────────────────────
# docker-compose.yml에서 기본값 사용하므로 보통 불필요
# JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0
